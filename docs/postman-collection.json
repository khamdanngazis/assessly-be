{
  "info": {
    "name": "Assessly API",
    "_postman_id": "assessly-backend-api",
    "description": "Complete API collection for Assessly Backend System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{jwt_token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://assessly-be-production.up.railway.app/api/v1",
      "type": "string"
    },
    {
      "key": "jwt_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "test_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "submission_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "question_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "answer_id",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/../../health",
              "host": ["{{base_url}}"],
              "path": ["", "", "health"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register Creator",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const response = pm.response.json();",
                  "    console.log('Creator ID:', response.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Creator\",\n  \"email\": \"creator@example.com\",\n  \"password\": \"TestPassword123!\",\n  \"role\": \"creator\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": ["{{base_url}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "Login Creator",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    pm.collectionVariables.set('jwt_token', response.token);",
                  "    console.log('JWT Token saved:', response.token.substring(0, 20) + '...');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"creator@example.com\",\n  \"password\": \"TestPassword123!\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Register Reviewer",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Reviewer\",\n  \"email\": \"reviewer@example.com\",\n  \"password\": \"TestPassword123!\",\n  \"role\": \"reviewer\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": ["{{base_url}}"],
              "path": ["auth", "register"]
            }
          }
        }
      ]
    },
    {
      "name": "Tests (Creator)",
      "item": [
        {
          "name": "Create Test",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const response = pm.response.json();",
                  "    pm.collectionVariables.set('test_id', response.id);",
                  "    console.log('Test ID saved:', response.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"JavaScript Fundamentals\",\n  \"description\": \"Test your knowledge of JavaScript basics\",\n  \"allow_retakes\": false\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/tests",
              "host": ["{{base_url}}"],
              "path": ["tests"]
            }
          }
        },
        {
          "name": "Add Question",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const response = pm.response.json();",
                  "    pm.collectionVariables.set('question_id', response.id);",
                  "    console.log('Question ID saved:', response.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"What is the difference between let and const in JavaScript?\",\n  \"expected_answer\": \"let allows reassignment, const does not\",\n  \"order_num\": 1\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/tests/{{test_id}}/questions",
              "host": ["{{base_url}}"],
              "path": ["tests", "{{test_id}}", "questions"]
            }
          }
        },
        {
          "name": "Publish Test",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/tests/{{test_id}}/publish",
              "host": ["{{base_url}}"],
              "path": ["tests", "{{test_id}}", "publish"]
            }
          }
        },
        {
          "name": "Generate Access Token (NEW)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    pm.collectionVariables.set('access_token', response.access_token);",
                  "    console.log('Access Token saved:', response.access_token.substring(0, 20) + '...');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"participant@example.com\",\n  \"expiry_hours\": 24\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/tests/{{test_id}}/access-token",
              "host": ["{{base_url}}"],
              "path": ["tests", "{{test_id}}", "access-token"]
            }
          }
        }
      ]
    },
    {
      "name": "Submissions (Participant)",
      "item": [
        {
          "name": "Submit Test",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const response = pm.response.json();",
                  "    pm.collectionVariables.set('submission_id', response.id);",
                  "    console.log('Submission ID saved:', response.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "X-Access-Token",
                "value": "{{access_token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"answers\": [\n    {\n      \"question_id\": \"{{question_id}}\",\n      \"text\": \"let allows you to reassign values to the variable, while const creates a constant reference that cannot be reassigned after initialization.\"\n    }\n  ]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/submissions",
              "host": ["{{base_url}}"],
              "path": ["submissions"]
            }
          }
        },
        {
          "name": "Get Submission with AI Scores",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [
              {
                "key": "X-Access-Token",
                "value": "{{access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/submissions/{{submission_id}}",
              "host": ["{{base_url}}"],
              "path": ["submissions", "{{submission_id}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Reviews (Reviewer)",
      "item": [
        {
          "name": "List Submissions",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/tests/{{test_id}}/submissions",
              "host": ["{{base_url}}"],
              "path": ["tests", "{{test_id}}", "submissions"]
            }
          }
        },
        {
          "name": "Add Manual Review",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"score\": 95,\n  \"feedback\": \"Great answer! Very clear explanation.\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/reviews/{{answer_id}}/manual",
              "host": ["{{base_url}}"],
              "path": ["reviews", "{{answer_id}}", "manual"]
            }
          }
        }
      ]
    }
  ]
}
